# ── Mac / local development ──────────────────────────────────────────────────
# Point the dashboard at your local FastAPI backend (uvicorn on :8000).
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Data source: "live" = real endpoints + mock fallback; "mock" = fully offline.
NEXT_PUBLIC_DATA_SOURCE=live

# App runs at the root in dev (http://localhost:3100). Leave BASE_PATH empty.
NEXT_PUBLIC_BASE_PATH=

# ── Server (internet.acuronai.com/admin) ─────────────────────────────────────
# On the EC2 box, build with:
#   NEXT_PUBLIC_API_BASE=            (empty -> same-origin, nginx proxies /api,/tickets to backend)
#   NEXT_PUBLIC_DATA_SOURCE=live
#   NEXT_PUBLIC_BASE_PATH=/admin
# The deploy script (deploy/deploy_dashboard.sh) sets these for you.
