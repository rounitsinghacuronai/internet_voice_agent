# ── API keys (required for live voice) ──
SARVAM_API_KEY=
GEMINI_API_KEY=

# ── models ──
GEMINI_MODEL=gemini-2.5-flash
GEMINI_REASONING_EFFORT=none
STT_MODEL=saaras:v3
STT_MODE=codemix
TTS_MODEL=bulbul:v3
TTS_SPEAKER=priya
TTS_PACE=1.2               # speaking speed; per-style pace multiplies this, clamped by SPEECH_PACE_MAX

# ── infra ──
PORT=8000
LOG_LEVEL=INFO
LOG_JSON=0
QDRANT_URL=              # e.g. http://localhost:6333 ; empty = in-memory store

# ── Exotel telephony (bidirectional Voicebot streaming) ──
EXOTEL_ENABLED=true
EXOTEL_SAMPLE_RATE=16000   # must match ?sample-rate= on the Voicebot URL; 8000|16000|24000
EXOTEL_API_KEY=            # optional Basic auth (set both to require wss://key:token@host)
EXOTEL_API_TOKEN=

# ── Human Speech Generation Engine + Voice Director ──
SPEECH_ENABLED=true            # deterministic natural-speech layer before TTS; false = raw sentence → TTS
SPEECH_LLM_RESTRUCTURE=false   # optional micro-LLM restructuring pass (higher polish, adds latency)
SPEECH_PACE_MIN=0.7            # lower clamp on per-utterance Sarvam pace
SPEECH_PACE_MAX=1.25           # upper clamp on per-utterance Sarvam pace

# ── tuning ──
VAD_END_SILENCE_MS=500         # dead air after caller stops before reply; lower = snappier (500-650)
VERIFY_TTL_S=1800
