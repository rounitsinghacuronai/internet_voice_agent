# ── API keys (required for live voice) ──
SARVAM_API_KEY=
GEMINI_API_KEY=

# ── models ──
GEMINI_MODEL=gemini-2.5-flash
GEMINI_REASONING_EFFORT=none
STT_MODEL=saaras:v3
STT_MODE=codemix
TTS_MODEL=bulbul:v3
TTS_SPEAKER=priya
TTS_PACE=1.0               # speaking speed; per-style pace multiplies this, clamped by SPEECH_PACE_MAX
# Output loudness leveling — keeps the agent's OWN volume steady between
# sentences (Sarvam returns each at a slightly different level; the drift is an
# AI tell). Reference-free, one constant gain per sentence (no pumping, no added
# latency), gentle ±6 dB by default. On by default; tune or disable below.
TTS_LOUDNESS_NORMALIZE=true
TTS_LOUDNESS_AVG_ALPHA=0.30      # how fast the running level adapts (0=frozen,1=last sentence)
TTS_LOUDNESS_MAX_GAIN=2.0        # loudest boost for a too-quiet sentence (+6 dB)
TTS_LOUDNESS_MIN_GAIN=0.5        # deepest cut for a too-loud sentence (-6 dB)

# ── infra ──
PORT=8000
LOG_LEVEL=INFO
LOG_JSON=0
QDRANT_URL=              # e.g. http://localhost:6333 ; empty = in-memory store

# ── Exotel telephony (bidirectional Voicebot streaming) ──
EXOTEL_ENABLED=true
EXOTEL_SAMPLE_RATE=16000   # must match ?sample-rate= on the Voicebot URL; 8000|16000|24000
EXOTEL_API_KEY=            # optional Basic auth (set both to require wss://key:token@host)
EXOTEL_API_TOKEN=

# ── Human Speech Generation Engine + Voice Director ──
SPEECH_ENABLED=true            # deterministic natural-speech layer before TTS; false = raw sentence → TTS
SPEECH_LLM_RESTRUCTURE=false   # optional micro-LLM restructuring pass (higher polish, adds latency)
SPEECH_PACE_MIN=0.7            # lower clamp on per-utterance Sarvam pace
SPEECH_PACE_MAX=1.25           # upper clamp on per-utterance Sarvam pace

# ── latency (900–1200 ms speech-to-speech with both streams on) ──
STT_STREAMING_ENABLED=true       # transcribe WHILE the caller speaks (≈ -300 ms; costs more STT ₹)
TTS_STREAMING_ENABLED=true       # first audio chunk from the TTS WebSocket (≈ -150–300 ms)
STT_EARLY_FLUSH_SILENCE_MS=200   # flush Sarvam early inside the endpoint hangover (≈ -100–200 ms)
LLM_FIRST_FLUSH_CHARS=80         # first-audio comma-flush threshold, first segment only

# ── tuning ──
VAD_END_SILENCE_MS=400         # dead air after caller stops before reply; lower = snappier (400-650)
VERIFY_TTL_S=1800

# ── persona (single source of identity — backend/app/persona.py) ──
AGENT_NAME=Ratan
AGENT_GENDER=male          # male | female — controls greeting, mr/hi first-person grammar, default voice
# AGENT_ROLE=customer care executive

# ── WhatsApp ops notifications (POC — backend/app/notification_service/) ──
WHATSAPP_ENABLED=false           # true → send; false → full pipeline, console-only sender
WHATSAPP_PROVIDER=personal       # personal (whatsapp_bridge sidecar) | meta | twilio | exotel
WHATSAPP_GROUP_NAME=Operations   # exact WhatsApp group name the POC account is a member of
WHATSAPP_BRIDGE_URL=http://127.0.0.1:3001
WHATSAPP_RETRY_MAX=3
WHATSAPP_RETRY_BASE_S=2.0
WHATSAPP_DEDUP_WINDOW_MIN=60     # same customer + category inside this window → follow-up, not spam
WHATSAPP_LLM_SUMMARY=false       # background Gemini polish of the ops summary (optional)
# NOTIFY_S3_BUCKET=              # optional: mirror the audit trail to S3
